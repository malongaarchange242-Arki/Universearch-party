# PassEvent - Configuration Example
# Copy this file to .env and fill in your own values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
# For Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/pass_event"

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Server port (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ==========================================
# MTN MOMO API CONFIGURATION
# ==========================================

# Your MTN MoMo API User (from https://momodeveloper.mtn.com)
MOMO_API_USER="your_momo_api_user_here"

# Your MTN MoMo API Key
MOMO_API_KEY="your_momo_api_key_here"

# Your MTN MoMo Subscription Key
MOMO_SUBSCRIPTION_KEY="your_momo_subscription_key_here"

# MoMo Environment (sandbox | production)
MOMO_ENVIRONMENT="sandbox"

# Currency for MoMo transactions (EUR, USD, XAF, etc.)
MOMO_COLLECTION_CURRENCY="EUR"

# Callback URL for MoMo webhooks
MOMO_CALLBACK_URL="http://localhost:3000/payments/callback"

# ==========================================
# JWT CONFIGURATION (Optional - for future use)
# ==========================================

# Secret key for JWT signing
JWT_SECRET="your_jwt_secret_key_change_this_in_production"

# ==========================================
# ENVIRONMENT SETUP TIPS
# ==========================================

# 1. Database Setup
# - Local PostgreSQL:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/pass_event"
#
# - Supabase:
#   DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ID].supabase.co:5432/postgres"

# 2. MTN MoMo API
# - Register at: https://momodeveloper.mtn.com
# - Get your credentials from dashboard
# - Start with sandbox for testing

# 3. Upload this to production hosting
# - Heroku: heroku config:set DATABASE_URL=...
# - Railway: Settings → Variables
# - Docker: Environment variables in docker-compose.yml
